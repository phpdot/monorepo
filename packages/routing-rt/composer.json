{
    "name": "phpdot/routing-rt",
    "description": "Real-time routing for WebSocket and SSE — extends phpdot/routing.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["routing", "websocket", "sse", "real-time", "swoole"],
    "require": {
        "php": ">=8.5",
        "phpdot/contracts": "^0.1",
        "phpdot/realtime": "^0.1",
        "phpdot/routing": "^0.1",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpdot/container": "^0.1",
        "phpdot/http": "^0.1",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Routing\\RouterRT\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Routing\\RouterRT\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "support": {
        "source": "https://github.com/phpdot/routing-rt",
        "issues": "https://github.com/phpdot/monorepo/issues"
    }
}
