{
    "name": "phpdot/server",
    "description": "Swoole HTTP, WebSocket, and TCP server for PSR-15 handlers.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": [
        "server",
        "swoole",
        "http",
        "websocket",
        "tcp",
        "psr-15"
    ],
    "require": {
        "php": ">=8.5",
        "ext-swoole": ">=6.2",
        "phpdot/contracts": "^0.1",
        "phpdot/http": "^0.1",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpdot/container": "^0.1",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.0",
        "swoole/ide-helper": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Server\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Server\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "support": {
        "source": "https://github.com/phpdot/server",
        "issues": "https://github.com/phpdot/monorepo/issues"
    }
}
