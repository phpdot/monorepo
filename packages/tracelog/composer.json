{
    "name": "phpdot/tracelog",
    "description": "Channel-based log backend: handlers, formatters, and fail-closed record encryption.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": [
        "logging",
        "channels",
        "handlers",
        "encryption",
        "observability"
    ],
    "require": {
        "php": ">=8.5",
        "ext-openssl": "*",
        "phpdot/container": "^0.1",
        "phpdot/contracts": "^0.1",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\TraceLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\TraceLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "support": {
        "source": "https://github.com/phpdot/tracelog",
        "issues": "https://github.com/phpdot/monorepo/issues"
    }
}
