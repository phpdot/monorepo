{
    "name": "phpdot/container-swoole",
    "description": "Swoole context provider and per-request dispatcher for phpdot/container",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": [
        "swoole",
        "coroutine",
        "container",
        "context",
        "scope"
    ],
    "require": {
        "php": ">=8.5",
        "ext-swoole": ">=6.2",
        "phpdot/container": "^0.1",
        "phpdot/contracts": "^0.1",
        "psr/container": "^1.1 || ^2.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.0",
        "swoole/ide-helper": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Container\\Swoole\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Container\\Swoole\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "support": {
        "source": "https://github.com/phpdot/container-swoole",
        "issues": "https://github.com/phpdot/monorepo/issues"
    }
}
