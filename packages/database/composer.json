{
    "name": "phpdot/database",
    "description": "Query builder, schema management, and migrations for PHP. Built on Doctrine DBAL.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["database", "query-builder", "schema", "migrations", "mysql", "postgresql", "sqlite", "dbal"],
    "require": {
        "php": ">=8.5",
        "doctrine/dbal": "^4.4",
        "phpdot/contracts": "^0.1",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpdot/container": "^0.1",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Database\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Database\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "support": {
        "source": "https://github.com/phpdot/database",
        "issues": "https://github.com/phpdot/monorepo/issues"
    }
}
