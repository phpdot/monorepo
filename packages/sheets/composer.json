{
    "name": "phpdot/sheets",
    "description": "Fast, streaming, low-memory XLSX reader and writer with charts, images, conditional formatting and data validation as opt-in plugins.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["spreadsheet", "xlsx", "excel", "ooxml", "streaming", "phpdot"],
    "require": {
        "php": ">=8.5",
        "ext-zip": "*",
        "ext-mbstring": "*",
        "ext-xmlreader": "*",
        "ext-simplexml": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpdot/container": "^0.1",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Sheets\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Sheets\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=512M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "support": {
        "source": "https://github.com/phpdot/sheets",
        "issues": "https://github.com/phpdot/monorepo/issues"
    }
}
