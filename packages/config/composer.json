{
    "name": "phpdot/config",
    "description": "Typed, cached, dot-notation configuration for modern PHP.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": [
        "config",
        "configuration",
        "dot-notation",
        "cache",
        "typed"
    ],
    "require": {
        "php": ">=8.5"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Config\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Config\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "support": {
        "source": "https://github.com/phpdot/config",
        "issues": "https://github.com/phpdot/monorepo/issues"
    }
}
