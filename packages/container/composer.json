{
    "name": "phpdot/container",
    "description": "Server-agnostic service scoping for PHP-DI",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["container", "di", "php-di", "scope", "swoole", "coroutine"],
    "require": {
        "php": ">=8.5",
        "php-di/php-di": "^7.0",
        "phpdot/attribute": "^0.1",
        "phpdot/contracts": "^0.1",
        "psr/container": "^2.0",
        "symfony/console": "^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.0",
        "psr/log": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Container\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Container\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "support": {
        "source": "https://github.com/phpdot/container",
        "issues": "https://github.com/phpdot/monorepo/issues"
    }
}
