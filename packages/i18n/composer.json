{
    "name": "phpdot/i18n",
    "description": "Internationalization with ICU MessageFormat, pluggable loaders, PSR-16 caching.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["i18n", "internationalization", "translation", "icu", "messageformat", "locale", "psr-16"],
    "require": {
        "php": ">=8.5",
        "ext-intl": "*",
        "phpdot/contracts": "^0.1",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpdot/container": "^0.1",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\I18n\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\I18n\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "support": {
        "source": "https://github.com/phpdot/i18n",
        "issues": "https://github.com/phpdot/monorepo/issues"
    }
}
