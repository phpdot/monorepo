{
    "name": "phpdot/monorepo",
    "description": "PHPdot framework monorepo — every phpdot package, developed and tested together.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "require": {
        "php": ">=8.5",
        "ext-curl": "*",
        "ext-gd": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-mongodb": "^2.1",
        "ext-openssl": "*",
        "ext-redis": "^6.0",
        "ext-simplexml": "*",
        "ext-swoole": ">=6.2",
        "ext-xmlreader": "*",
        "ext-zip": "*",
        "bacon/bacon-qr-code": "^3.0",
        "doctrine/dbal": "^4.4",
        "league/mime-type-detection": "^1.16",
        "mongodb/mongodb": "^2.1",
        "nyholm/psr7": "^1.8",
        "php-amqplib/php-amqplib": "^3.0",
        "php-di/php-di": "^7.0",
        "psr/clock": "^1.0",
        "psr/container": "^2.0",
        "psr/event-dispatcher": "^1.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0",
        "psr/simple-cache": "^3.0",
        "symfony/console": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/mailer": "^8.0",
        "symfony/mime": "^8.0",
        "symfony/process": "^8.0",
        "twig/twig": "^3.10"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13.0",
        "swoole/ide-helper": "^6.0"
    },
    "replace": {
        "phpdot/attribute": "self.version",
        "phpdot/bun": "self.version",
        "phpdot/cache": "self.version",
        "phpdot/config": "self.version",
        "phpdot/console": "self.version",
        "phpdot/container": "self.version",
        "phpdot/container-swoole": "self.version",
        "phpdot/contracts": "self.version",
        "phpdot/database": "self.version",
        "phpdot/env": "self.version",
        "phpdot/error": "self.version",
        "phpdot/error-handler": "self.version",
        "phpdot/filesystem": "self.version",
        "phpdot/event": "self.version",
        "phpdot/http": "self.version",
        "phpdot/http-middleware": "self.version",
        "phpdot/i18n": "self.version",
        "phpdot/logs": "self.version",
        "phpdot/mail": "self.version",
        "phpdot/mongodb": "self.version",
        "phpdot/package": "self.version",
        "phpdot/path": "self.version",
        "phpdot/pool": "self.version",
        "phpdot/psr3-bridge": "self.version",
        "phpdot/qrcode": "self.version",
        "phpdot/rabbitmq": "self.version",
        "phpdot/realtime": "self.version",
        "phpdot/redis": "self.version",
        "phpdot/routing": "self.version",
        "phpdot/routing-rt": "self.version",
        "phpdot/server": "self.version",
        "phpdot/template": "self.version",
        "phpdot/session": "self.version",
        "phpdot/sheets": "self.version",
        "phpdot/totp": "self.version",
        "phpdot/tracelog": "self.version",
        "phpdot/validator": "self.version"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Attribute\\": "packages/attribute/src/",
            "PHPdot\\Bun\\": "packages/bun/src/",
            "PHPdot\\Cache\\": "packages/cache/src/",
            "PHPdot\\Config\\": "packages/config/src/",
            "PHPdot\\Console\\": "packages/console/src/",
            "PHPdot\\Container\\": "packages/container/src/",
            "PHPdot\\Container\\Swoole\\": "packages/container-swoole/src/",
            "PHPdot\\Contracts\\": "packages/contracts/src/",
            "PHPdot\\Database\\": "packages/database/src/",
            "PHPdot\\Env\\": "packages/env/src/",
            "PHPdot\\Error\\": "packages/error/src/",
            "PHPdot\\ErrorHandler\\": "packages/error-handler/src/",
            "PHPdot\\Filesystem\\": "packages/filesystem/src/",
            "PHPdot\\Event\\": "packages/event/src/",
            "PHPdot\\Http\\": "packages/http/src/",
            "PHPdot\\HttpMiddleware\\": "packages/http-middleware/src/",
            "PHPdot\\I18n\\": "packages/i18n/src/",
            "PHPdot\\Logs\\": "packages/logs/src/",
            "PHPdot\\Mail\\": "packages/mail/src/",
            "PHPdot\\MongoDB\\": "packages/mongodb/src/",
            "PHPdot\\Package\\": "packages/package/src/",
            "PHPdot\\Path\\": "packages/path/src/",
            "PHPdot\\Pool\\": "packages/pool/src/",
            "PHPdot\\Psr3Bridge\\": "packages/psr3-bridge/src/",
            "PHPdot\\QrCode\\": "packages/qrcode/src/",
            "PHPdot\\RabbitMQ\\": "packages/rabbitmq/src/",
            "PHPdot\\Realtime\\": "packages/realtime/src/",
            "PHPdot\\Redis\\": "packages/redis/src/",
            "PHPdot\\Routing\\": "packages/routing/src/",
            "PHPdot\\Routing\\RouterRT\\": "packages/routing-rt/src/",
            "PHPdot\\Server\\": "packages/server/src/",
            "PHPdot\\Template\\": "packages/template/src/",
            "PHPdot\\Session\\": "packages/session/src/",
            "PHPdot\\Sheets\\": "packages/sheets/src/",
            "PHPdot\\TraceLog\\": "packages/tracelog/src/",
            "PHPdot\\Totp\\": "packages/totp/src/",
            "PHPdot\\Validator\\": "packages/validator/src/"
        },
        "files": [
            "packages/container/src/functions.php",
            "packages/env/src/functions.php",
            "packages/logs/src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Http\\Psr7Test\\": "packages/http/tests/Psr7/",
            "PHPdot\\Attribute\\Tests\\": "packages/attribute/tests/",
            "PHPdot\\Bun\\Tests\\": "packages/bun/tests/",
            "PHPdot\\Cache\\Tests\\": "packages/cache/tests/",
            "PHPdot\\Config\\Tests\\": "packages/config/tests/",
            "PHPdot\\Console\\Tests\\": "packages/console/tests/",
            "PHPdot\\Container\\Swoole\\Tests\\": "packages/container-swoole/tests/",
            "PHPdot\\Container\\Tests\\": "packages/container/tests/",
            "PHPdot\\Database\\Tests\\": "packages/database/tests/",
            "PHPdot\\Env\\Tests\\": "packages/env/tests/",
            "PHPdot\\Error\\Tests\\": "packages/error/tests/",
            "PHPdot\\ErrorHandler\\Tests\\": "packages/error-handler/tests/",
            "PHPdot\\Filesystem\\Tests\\": "packages/filesystem/tests/",
            "PHPdot\\Event\\Tests\\": "packages/event/tests/",
            "PHPdot\\Http\\Tests\\": "packages/http/tests/",
            "PHPdot\\HttpMiddleware\\Tests\\": "packages/http-middleware/tests/",
            "PHPdot\\I18n\\Tests\\": "packages/i18n/tests/",
            "PHPdot\\Logs\\Tests\\": "packages/logs/tests/",
            "PHPdot\\Mail\\Tests\\": "packages/mail/tests/",
            "PHPdot\\MongoDB\\Tests\\": "packages/mongodb/tests/",
            "PHPdot\\Package\\Tests\\": "packages/package/tests/",
            "PHPdot\\Path\\Tests\\": "packages/path/tests/",
            "PHPdot\\Pool\\Tests\\": "packages/pool/tests/",
            "PHPdot\\Psr3Bridge\\Tests\\": "packages/psr3-bridge/tests/",
            "PHPdot\\QrCode\\Tests\\": "packages/qrcode/tests/",
            "PHPdot\\RabbitMQ\\Tests\\": "packages/rabbitmq/tests/",
            "PHPdot\\Realtime\\Tests\\": "packages/realtime/tests/",
            "PHPdot\\Redis\\Tests\\": "packages/redis/tests/",
            "PHPdot\\Routing\\Tests\\": "packages/routing/tests/",
            "PHPdot\\Routing\\RouterRT\\Tests\\": "packages/routing-rt/tests/",
            "PHPdot\\Server\\Tests\\": "packages/server/tests/",
            "PHPdot\\Template\\Tests\\": "packages/template/tests/",
            "PHPdot\\Session\\Tests\\": "packages/session/tests/",
            "PHPdot\\Sheets\\Tests\\": "packages/sheets/tests/",
            "PHPdot\\TraceLog\\Tests\\": "packages/tracelog/tests/",
            "PHPdot\\Totp\\Tests\\": "packages/totp/tests/",
            "PHPdot\\Validator\\Tests\\": "packages/validator/tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=1G",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
